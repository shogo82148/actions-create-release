{
  "name": "actions-create-release",
  "version": "1.7.6",
  "private": true,
  "type": "module",
  "description": "Create a release for a tag in your repository",
  "engines": {
    "node": "^24.0.0"
  },
  "scripts": {
    "bundle": "npm run format:write && npm run package",
    "format:write": "prettier --write .",
    "format:check": "prettier --check .",
    "lint": "npx eslint .",
    "package": "npx rimraf ./dist && npx rollup --config rollup.config.mjs",
    "test": "node --experimental-vm-modules node_modules/.bin/jest",
    "all": "npm run format:write && npm run lint && npm run package && npm test"
  },
  "repository": {
    "type": "git",
    "url": "git+https://github.com/shogo82148/actions-create-release.git"
  },
  "keywords": [
    "actions",
    "node",
    "setup"
  ],
  "author": "",
  "license": "MIT",
  "dependencies": {
    "@actions/core": "^3.0.1",
    "@actions/http-client": "^4.0.1",
    "tslib": "^2.8.1"
  },
  "devDependencies": {
    "@eslint/js": "^10.0.1",
    "@rollup/plugin-commonjs": "^29.0.2",
    "@rollup/plugin-node-resolve": "^16.0.3",
    "@rollup/plugin-typescript": "^12.3.0",
    "@types/eslint__js": "^8.42.3",
    "@types/jest": "^30.0.0",
    "@types/node": "^24.12.0",
    "eslint": "^10.3.0",
    "jest": "^30.3.0",
    "js-yaml": "^4.1.1",
    "prettier": "3.8.3",
    "rollup": "^4.60.2",
    "ts-jest": "^29.4.9",
    "typescript": "^6.0.3",
    "typescript-eslint": "^8.59.2"
  }
}
